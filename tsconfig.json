{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "out",
    "paths": {
      "@shared/*": [
        "shared/*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "shared/**/*",
    "electron.vite.config.ts"
  ]
}